+    void HandleTouchTap(uint16_t x, uint16_t y) {
+        auto& app = Application::GetInstance();
+        auto state = app.GetDeviceState();
+        ESP_LOGI(TAG, "Touch tap at (%u, %u), state=%d", x, y, (int)state);
+
+        if (state == kDeviceStateSpeaking) {
+            app.Schedule([]() {
+                auto& app = Application::GetInstance();
+                app.AbortSpeaking(kAbortReasonNone);
+                Board::GetInstance().GetDisplay()->ShowNotification("已停止播放", 1000);
+            });
+        } else if (state == kDeviceStateListening) {
+            app.StopListening();
+            Board::GetInstance().GetDisplay()->ShowNotification("已停止聆听", 1000);
+        }
+    }
