+    void HandleTouchTap(uint16_t x, uint16_t y) {
+        auto& app = Application::GetInstance();
+        auto state = app.GetDeviceState();
+        ESP_LOGI(TAG, "Touch tap at (%u, %u), state=%d", x, y, (int)state);
+
+        if (state == kDeviceStateSpeaking) {
+            app.Schedule([]() {
+                auto& app = Application::GetInstance();
+                app.AbortSpeaking(kAbortReasonNone);
+                Board::GetInstance().GetDisplay()->ShowNotification("已停止播放", 1000);
+            });
+        } else if (state == kDeviceStateListening) {
+            app.StopListening();
+            Board::GetInstance().GetDisplay()->ShowNotification("已停止聆听", 1000);
+        }
+    }
+
+    void TouchTask() {
+        bool was_touched = false;
+        int64_t touch_down_ms = 0;
+        int64_t last_tap_ms = 0;
+        uint16_t last_x = 0;
+        uint16_t last_y = 0;
+
+        while (true) {
+            if (touch_ == nullptr) {
+                vTaskDelay(pdMS_TO_TICKS(100));
+                continue;
+            }
+
+            esp_lcd_touch_read_data(touch_);
+            uint16_t x[1] = {0};
+            uint16_t y[1] = {0};
+            uint16_t strength[1] = {0};
+            uint8_t point_num = 0;
+            bool touched = esp_lcd_touch_get_coordinates(touch_, x, y, strength, &point_num, 1) && point_num > 0;
+            int64_t now_ms = esp_timer_get_time() / 1000;
+
+            if (touched && !was_touched) {
+                was_touched = true;
+                touch_down_ms = now_ms;
+                last_x = x[0];
+                last_y = y[0];
+            } else if (!touched && was_touched) {
+                was_touched = false;
+                int64_t duration_ms = now_ms - touch_down_ms;
+                if (duration_ms > 30 && duration_ms < 800 && now_ms - last_tap_ms > 300) {
+                    last_tap_ms = now_ms;
+                    HandleTouchTap(last_x, last_y);
+                }
+            }
+
+            vTaskDelay(pdMS_TO_TICKS(30));
+        }
+    }
