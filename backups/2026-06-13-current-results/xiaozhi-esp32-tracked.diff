+    void HandleTouchLongPress(uint16_t x, uint16_t y) {
+        auto codec = GetAudioCodec();
+        int volume = codec != nullptr ? codec->output_volume() : 0;
+        ESP_LOGI(TAG, "Touch long press at (%u, %u), volume=%d", x, y, volume);
+        char message[48];
+        snprintf(message, sizeof(message), "音量 %d%% · 设置面板", volume);
+        Board::GetInstance().GetDisplay()->ShowNotification(message, 1500);
+    }
+
+    void HandleTouchSwipe(int dx) {
+        subtitle_visible_ = !subtitle_visible_;
+        auto display = Board::GetInstance().GetDisplay();
+        auto lcd_display = dynamic_cast<LcdDisplay*>(display);
+        if (lcd_display != nullptr) {
+            lcd_display->SetHideSubtitle(!subtitle_visible_);
+        }
+        ESP_LOGI(TAG, "Touch swipe dx=%d, subtitle_visible=%d", dx, subtitle_visible_);
+        display->ShowNotification(subtitle_visible_ ? "字幕页" : "状态页", 1200);
+    }
+
+    void TouchTask() {
+        bool was_touched = false;
+        int64_t touch_down_ms = 0;
+        int64_t last_tap_ms = 0;
+        uint16_t last_x = 0;
+        uint16_t last_y = 0;
+        uint16_t current_x = 0;
+        uint16_t current_y = 0;
+
+        while (true) {
+            if (touch_ == nullptr) {
+                vTaskDelay(pdMS_TO_TICKS(100));
+                continue;
+            }
+
+            esp_lcd_touch_read_data(touch_);
+            uint16_t x[1] = {0};
+            uint16_t y[1] = {0};
+            uint16_t strength[1] = {0};
+            uint8_t point_num = 0;
+            bool touched = esp_lcd_touch_get_coordinates(touch_, x, y, strength, &point_num, 1) && point_num > 0;
+            int64_t now_ms = esp_timer_get_time() / 1000;
+
+            if (touched && !was_touched) {
+                was_touched = true;
+                touch_down_ms = now_ms;
+                last_x = x[0];
+                last_y = y[0];
+                current_x = x[0];
+                current_y = y[0];
+            } else if (touched && was_touched) {
+                current_x = x[0];
+                current_y = y[0];
+            } else if (!touched && was_touched) {
+                was_touched = false;
+                int64_t duration_ms = now_ms - touch_down_ms;
+                int dx = (int)current_x - (int)last_x;
+                int dy = (int)current_y - (int)last_y;
+                if (std::abs(dx) > 120 && std::abs(dx) > std::abs(dy) * 2) {
+                    HandleTouchSwipe(dx);
+                } else if (duration_ms >= 800) {
+                    HandleTouchLongPress(last_x, last_y);
+                } else if (duration_ms > 30 && now_ms - last_tap_ms > 300) {
+                    last_tap_ms = now_ms;
+                    HandleTouchTap(last_x, last_y);
+                }
+            }
+
+            vTaskDelay(pdMS_TO_TICKS(30));
+        }
+    }
