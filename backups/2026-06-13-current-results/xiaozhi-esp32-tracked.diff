+    virtual bool GetBatteryLevel(int &level, bool& charging, bool& discharging) override {
+        if (ina226_ == nullptr) {
+            ESP_LOGW(TAG, "Battery: INA226 is not initialized");
+            return false;
+        }
+
+        int mv = ina226_->ReadBusVoltageMv();
+        if (mv <= 0) {
+            level = 0;
+            charging = false;
+            discharging = false;
+            ESP_LOGW(TAG, "Battery: invalid INA226 bus voltage %dmV", mv);
+            return false;
+        }
+        if (mv < 5000 || mv > 9000) {
+            level = 0;
+            charging = false;
+            discharging = false;
+            return false;
+        }
+        int shunt_uv = ina226_->ReadShuntVoltageUv();
+        // Tab5 INA226: shunt V+ on battery side, V- on charger/load side
+        // Positive shunt = current OUT of battery = DISCHARGING
+        // Negative shunt = current INTO battery = CHARGING
+        const int kBatteryCurrentPresentUv = 1500;  // ~300mA with Tab5 5mOhm shunt
+        static int battery_present_score = 0;
+        bool current_present = std::abs(shunt_uv) >= kBatteryCurrentPresentUv;
+        if (current_present) {
+            if (battery_present_score < 5) {
+                battery_present_score++;
+            }
+        } else if (battery_present_score > 0) {
+            battery_present_score--;
+        }
+
+        discharging = (shunt_uv > kBatteryCurrentPresentUv) && battery_present_score >= 3;
+        charging = (shunt_uv < -kBatteryCurrentPresentUv) && battery_present_score >= 3;
+        if (battery_present_score < 3) {
+            level = 0;
+            ESP_LOGI(TAG, "Battery: not stable/present yet (%dmV shunt=%duV score=%d), hide battery icon",
+                     mv, shunt_uv, battery_present_score);
+            return false;
+        }
+        if (mv < 6000) {
+            level = 0;
+        } else {
+            level = (mv - 6000) * 100 / (8400 - 6000);
+            if (level < 0) level = 0;
+            if (level > 100) level = 100;
+        }
+
+        uint16_t raw_bus = 0;
+        int16_t raw_shunt = 0;
+        ina226_->ReadRawBusVoltage(raw_bus);
+        ina226_->ReadRawShuntVoltage(raw_shunt);
+        ESP_LOGI(TAG, "Battery: %dmV %d%% shunt=%duV ch=%d dis=%d raw_bus=0x%04x raw_shunt=%d",
+                 mv, level, shunt_uv, charging, discharging, raw_bus, raw_shunt);
+        return true;
+    }
