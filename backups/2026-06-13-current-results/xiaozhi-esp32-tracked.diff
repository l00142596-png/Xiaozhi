+
+    virtual bool GetBatteryLevel(int &level, bool& charging, bool& discharging) override {
+        if (ina226_ == nullptr) {
+            ESP_LOGW(TAG, "Battery: INA226 is not initialized");
+            return false;
+        }
+
+        int mv = ina226_->ReadBusVoltageMv();
+        if (mv <= 0) {
+            level = 0;
+            charging = false;
+            discharging = false;
+            ESP_LOGW(TAG, "Battery: invalid INA226 bus voltage %dmV", mv);
+            return true;
+        }
+        if (mv < 5000 || mv > 9000) {
+            level = 0;
+            charging = false;
+            discharging = false;
+            return true;
+        }
+        int shunt_uv = ina226_->ReadShuntVoltageUv();
+        // Tab5 INA226: shunt V+ on battery side, V- on charger/load side
+        // Positive shunt = current OUT of battery = DISCHARGING
+        // Negative shunt = current INTO battery = CHARGING
+        discharging = (shunt_uv > 50);
+        charging = (shunt_uv < -50);
+        if (!charging && !discharging && mv >= 6500 && mv <= 8300) {
+            level = 0;
+            ESP_LOGI(TAG, "Battery: no battery current detected (%dmV shunt=%duV), hide battery icon", mv, shunt_uv);
+            return false;
+        }
+        if (mv < 6000) {
+            level = 0;
+        } else {
+            level = (mv - 6000) * 100 / (8400 - 6000);
+            if (level < 0) level = 0;
+            if (level > 100) level = 100;
+        }
+
+        uint16_t raw_bus = 0;
+        int16_t raw_shunt = 0;
+        ina226_->ReadRawBusVoltage(raw_bus);
+        ina226_->ReadRawShuntVoltage(raw_shunt);
+        ESP_LOGI(TAG, "Battery: %dmV %d%% shunt=%duV ch=%d dis=%d raw_bus=0x%04x raw_shunt=%d",
+                 mv, level, shunt_uv, charging, discharging, raw_bus, raw_shunt);
+        return true;
+    }
